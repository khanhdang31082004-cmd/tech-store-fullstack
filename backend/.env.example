# Cấu hình cổng chạy Server Backend
PORT=5000

# Cấu hình kết nối MySQL Database
# Local dùng localhost, Railway dùng Environment Variables riêng
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tech_store

# Cấu hình bảo mật JWT Token
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# URL Frontend cho cấu hình CORS (dùng dấu phẩy nếu muốn cấu hình nhiều URL)
FRONTEND_URL=https://tech-store-fullstack-plum.vercel.app,http://localhost:5500,http://127.0.0.1:5500
